  clinic         Clinic               @relation(fields: [clinicId], references: [id])

  @@map("opening_balances")
}

model OpeningBalanceItem {
  id               String         @id @default(uuid())
  openingBalanceId String
  coaId            String
  debit            Float          @default(0)
  credit           Float          @default(0)
  coa              ChartOfAccount @relation(fields: [coaId], references: [id])
  openingBalance   OpeningBalance @relation(fields: [openingBalanceId], references: [id], onDelete: Cascade)

  @@map("opening_balance_items")
}

