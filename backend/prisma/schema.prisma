  purchaseNo    String                       @unique
  employeeName  String
  purchaseDate  DateTime                     @default(now())
  status        String                       @default("DRAFT")
  notes         String?
  totalAmount   Float                        @default(0)
  discount      Float                        @default(0)
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt
  clinicId      String
  paymentMethod String                       @default("CASH")
  items         DirectMedicinePurchaseItem[]
  clinic        Clinic                       @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([status])
  @@map("direct_medicine_purchases")
}

model DirectMedicinePurchaseItem {
  id                       String                 @id @default(uuid())
  directMedicinePurchaseId String
  productId                String
  batchId                  String?
  quantity                 Float
  unitPrice                Float
  subtotal                 Float
  directMedicinePurchase   DirectMedicinePurchase @relation(fields: [directMedicinePurchaseId], references: [id], onDelete: Cascade)
  product                  Product                @relation(fields: [productId], references: [id])
  batch                    InventoryBatch?        @relation(fields: [batchId], references: [id])

  @@index([directMedicinePurchaseId])
  @@index([productId])
  @@map("direct_medicine_purchase_items")
}

// ============================================================
// TREATMENT PLAN - Multi-Visit Medical Treatment with DP Scheme
// ============================================================

enum TreatmentPlanStatus {
  ACTIVE
  COMPLETED
}

/// Rangkaian perawatan medis bertahap (multi-visit).
/// Menjadi "payung" utama yang mengikat semua Visit dan satu Invoice.
/// Contoh: Perawatan Saluran Akar yang butuh 3 kunjungan.
model TreatmentPlan {
  id          String              @id @default(uuid())
  patientId   String
  description String // Nama/deskripsi rangkaian, misal "Perawatan Saluran Akar Gigi 36"
  totalAmount Float               @default(0)
  status      TreatmentPlanStatus @default(ACTIVE)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // === Relations ===
  patient        Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visits         Visit[]
  invoices       Invoice[]
  items          TreatmentPlanItem[]
  medicalRecords MedicalRecord[]

  @@index([patientId])
  @@index([status])
  @@map("treatment_plans")
}

/// Item perawatan detail pada Rangkaian Perawatan.
model TreatmentPlanItem {
  id              String    @id @default(uuid())
  treatmentPlanId String
  description     String
  quantity        Int       @default(1)
  price           Float     @default(0)
  subtotal        Float     @default(0)
  status          String    @default("PENDING")
  completedAt     DateTime?
  completedById   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  treatmentPlan TreatmentPlan @relation(fields: [treatmentPlanId], references: [id], onDelete: Cascade)

  @@index([treatmentPlanId])
  @@map("treatment_plan_items")
}

/// Catatan setiap kedatangan pasien dalam rangkaian perawatan.
model Visit {
  id              String   @id @default(uuid())
  treatmentPlanId String
  visitDate       DateTime @default(now())
  visitNumber     Int // Kunjungan ke-1, ke-2, ke-3, dst
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  treatmentPlan TreatmentPlan  @relation(fields: [treatmentPlanId], references: [id], onDelete: Cascade)
  medicalRecord MedicalRecord?

  @@index([treatmentPlanId])
  @@map("visits")
}
