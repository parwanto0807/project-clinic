generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinic {
  id                      String                   @id @default(uuid())
  name                    String
  code                    String                   @unique
  address                 String?
  phone                   String?
  email                   String?
  logo                    String?
  isActive                Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  isMain                  Boolean                  @default(false)
  deletedAt               DateTime?
  appointments            Appointment[]
  assetTransfersFrom      AssetTransfer[]          @relation("AssetTransferFrom")
  assetTransfersTo        AssetTransfer[]          @relation("AssetTransferTo")
  assets                  Asset[]
  banks                   Bank[]
  branchProductPrices     BranchProductPrice[]
  chartOfAccounts         ChartOfAccount[]
  compoundFormulas        CompoundFormula[]
  departments             Department[]
  doctorSchedules         DoctorSchedule[]
  expenses                Expense[]
  financialReports        FinancialReport[]
  transfersReceived       InterBranchTransfer[]    @relation("TransferDest")
  transfersSent           InterBranchTransfer[]    @relation("TransferSource")
  inventoryAuditLogs      InventoryAuditLog[]
  inventoryBatches        InventoryBatch[]
  inventoryMutations      InventoryMutation[]
  inventoryReturns        InventoryReturn[]
  inventoryStocks         InventoryStock[]
  invoices                Invoice[]
  journalEntries          JournalEntry[]
  medicalRecords          MedicalRecord[]
  medicines               Medicine[]
  openingBalances         OpeningBalance[]
  procurementPayments     ProcurementPayment[]
  procurements            Procurement[]
  products                Product[]
  queueNumbers            QueueNumber[]
  referrals               Referral[]
  registrations           Registration[]
  services                Service[]
  siteSettings            SiteSetting[]
  stockOpnames            StockOpnameSession[]
  systemAccounts          SystemAccount[]
  users                   UserClinic[]
  doctorCommissions       DoctorCommission[]
  cashTransfers           CashTransfer[]
  directMedicinePurchases DirectMedicinePurchase[]
  guestDoctorProfiles     GuestDoctorProfile[]
  guestDoctorAssignments  GuestDoctorAssignment[]

  @@map("clinics")
}

model UserClinic {
  id        String   @id @default(uuid())
  userId    String
  clinicId  String
  createdAt DateTime @default(now())
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clinicId])
  @@map("user_clinics")
}

model User {
  id               String                  @id @default(uuid())
  email            String?                 @unique // Nullable untuk guest account
  username         String                  @unique
  password         String
  name             String
  phone            String?
  isActive         Boolean                 @default(true)
  lastLogin        DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  role             Role                    @default(STAFF)
  image            String?
  deletedAt        DateTime?
  isGuestAccount   Boolean                 @default(false)
  guestExpiryDate  DateTime? // Kapan guest account expired
  activityLogs     ActivityLog[]
  doctor           Doctor?
  clinics          UserClinic[]
  guestAssignments GuestDoctorAssignment[]

  @@map("users")
}

model Patient {
  id                 String          @id @default(uuid())
  medicalRecordNo    String          @unique
  name               String
  email              String?
  phone              String
  address            String?
  city               String?
  province           String?
  zipCode            String?
  dateOfBirth        DateTime?
  gender             String?
  bloodType          String?
  identityType       String?
  identityNumber     String?
  emergencyContact   String?
  emergencyPhone     String?
  allergies          String?
  oldMedicalRecordNo String?         @unique
  familyHeadName     String?
  age                Float?
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  bpjsNumber         String?
  insuranceName      String?
  patientType        String?         @default("Poli Umum")
  appointments       Appointment[]
  invoices           Invoice[]
  labOrders          LabOrder[]
  medicalRecords     MedicalRecord[]
  prescriptions      Prescription[]
  queueNumbers       QueueNumber[]
  registrations      Registration[]
  treatmentPlans     TreatmentPlan[]

  @@index([medicalRecordNo])
  @@index([phone])
  @@map("patients")
}

model Registration {
  id               String         @id @default(uuid())
  patientId        String
  registrationNo   String
  registrationDate DateTime
  status           String         @default("completed")
  visitType        String
  referralDocument String?
  referralFrom     String?
  isDirectLab      Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  clinicId         String?
  departmentId     String?
  doctorId         String?
  invoices         Invoice[]
  medicalRecord    MedicalRecord?
  queueNumbers     QueueNumber[]
  labOrders        LabOrder[]
  clinic           Clinic?        @relation(fields: [clinicId], references: [id])
  department       Department?    @relation(fields: [departmentId], references: [id])
  doctor           Doctor?        @relation(fields: [doctorId], references: [id])
  patient          Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([registrationNo, clinicId])
  @@index([patientId])
  @@index([clinicId])
  @@map("registrations")
}

model Doctor {
  id                 String             @id @default(uuid())
  userId             String             @unique
  licenseNumber      String             @unique
  name               String
  email              String?            @unique
  phone              String
  specialization     String
  bio                String?
  profilePicture     String?
  yearsOfExperience  Int?
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  queueCode          String?
  appointments       Appointment[]
  managedDepartments Department[]       @relation("DeptHead")
  schedules          DoctorSchedule[]
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  labOrders          LabOrder[]
  medicalRecords     MedicalRecord[]
  prescriptions      Prescription[]
  queueNumbers       QueueNumber[]      @relation("QueueDoctor")
  registrations      Registration[]
  departments        Department[]       @relation("DoctorAllDepts")
  commissions        DoctorCommission[]

  @@index([specialization])
  @@map("doctors")
}

model DoctorSchedule {
  id        String   @id @default(uuid())
  doctorId  String
  dayOfWeek String
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clinicId  String?
  clinic    Clinic?  @relation(fields: [clinicId], references: [id])
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([clinicId])
  @@map("doctor_schedules")
}

// Master profile dokter tamu/guest (tersimpan permanent)
model GuestDoctorProfile {
  id             String   @id @default(uuid())
  name           String // "Dr. Supardi"
  licenseNumber  String   @unique // SIP dokter
  specialization String // "Umum", "Gigi", dll
  phone          String
  email          String? // Optional
  address        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  clinicId       String
  clinic         Clinic   @relation(fields: [clinicId], references: [id])

  assignments    GuestDoctorAssignment[]
  medicalRecords MedicalRecord[]

  @@index([clinicId])
  @@index([licenseNumber])
  @@map("guest_doctor_profiles")
}

// Assignment harian (dokter mana aktif hari ini)
model GuestDoctorAssignment {
  id            String             @id @default(uuid())
  date          DateTime           @db.Date // Tanggal assignment
  guestDoctorId String
  guestDoctor   GuestDoctorProfile @relation(fields: [guestDoctorId], references: [id], onDelete: Cascade)

  userId String? // Akun login temporary (optional)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdByAdminId String // Admin yang buat assignment
  status           String  @default("SCHEDULED") // SCHEDULED | ACTIVE | COMPLETED | CANCELLED
  notes            String? // "Pengganti Dr. Agus yang cuti"

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])

  medicalRecords MedicalRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, clinicId]) // Satu dokter tamu per hari per clinic
  @@index([guestDoctorId])
  @@index([date])
  @@index([clinicId])
  @@map("guest_doctor_assignments")
}

model Department {
  id             String         @id @default(uuid())
  name           String
  description    String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  level          Int            @default(0)
  parentId       String?
  sortOrder      Int            @default(0)
  clinicId       String?
  code           String?        @unique
  color          String?
  email          String?
  headId         String?
  icon           String?
  location       String?
  operatingHours Json?
  phone          String?
  clinic         Clinic?        @relation(fields: [clinicId], references: [id])
  head           Doctor?        @relation("DeptHead", fields: [headId], references: [id])
  parent         Department?    @relation("DeptHierarchy", fields: [parentId], references: [id])
  children       Department[]   @relation("DeptHierarchy")
  queueNumbers   QueueNumber[]  @relation("QueueDept")
  referrals      Referral[]
  registrations  Registration[]
  doctors        Doctor[]       @relation("DoctorAllDepts")
  services       Service[]

  @@index([parentId])
  @@map("departments")
}

model Appointment {
  id              String               @id @default(uuid())
  appointmentNo   String               @unique
  patientId       String
  doctorId        String
  appointmentDate DateTime
  appDurationMin  Int                  @default(30)
  status          String               @default("scheduled")
  notes           String?
  cancelReason    String?
  cancelledAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  clinicId        String?
  createdBy       String?
  reminderSent    Boolean              @default(false)
  updatedBy       String?
  services        AppointmentService[]
  clinic          Clinic?              @relation(fields: [clinicId], references: [id])
  doctor          Doctor               @relation(fields: [doctorId], references: [id])
  patient         Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medicalRecords  MedicalRecord[]

  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentDate])
  @@index([status])
  @@map("appointments")
}

model QueueNumber {
  id             String        @id @default(uuid())
  queueNo        String
  patientId      String
  appointmentId  String?
  queueDate      DateTime
  estimatedTime  DateTime?
  actualCallTime DateTime?
  status         String        @default("waiting")
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  clinicId       String?
  departmentId   String?
  doctorId       String?
  registrationId String?
  callCounter    Int           @default(0)
  clinic         Clinic?       @relation(fields: [clinicId], references: [id])
  department     Department?   @relation("QueueDept", fields: [departmentId], references: [id])
  doctor         Doctor?       @relation("QueueDoctor", fields: [doctorId], references: [id])
  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  registration   Registration? @relation(fields: [registrationId], references: [id])

  @@unique([queueNo, clinicId, queueDate])
  @@index([patientId])
  @@index([queueDate])
  @@index([status])
  @@map("queue_numbers")
}

model MedicalRecord {
  id                 String                    @id @default(uuid())
  recordNo           String                    @unique
  appointmentId      String?
  patientId          String
  doctorId           String?
  guestDoctorId      String? // Dokter guest/luar
  guestAssignmentId  String? // Assignment dokter guest hari itu
  chiefComplaint     String
  diagnosis          String?
  icd10Id            String?
  icd10              Icd10?                    @relation(fields: [icd10Id], references: [id])
  treatmentPlan      String?
  notes              String?
  recordDate         DateTime                  @default(now())
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  clinicId           String?
  consultationDraft  Json?
  labNotes           String?
  labResults         String?
  registrationId     String?                   @unique
  hasInformedConsent Boolean                   @default(false)
  objective          String?
  subjective         String?
  labOrders          LabOrder[]
  attachments        MedicalRecordAttachment[]
  services           MedicalRecordService[]
  treatmentPlanId    String?
  visitId            String?                   @unique
  treatmentPlanRef   TreatmentPlan?            @relation(fields: [treatmentPlanId], references: [id])
  visitRef           Visit?                    @relation(fields: [visitId], references: [id])
  appointment        Appointment?              @relation(fields: [appointmentId], references: [id])
  clinic             Clinic?                   @relation(fields: [clinicId], references: [id])
  doctor             Doctor?                   @relation(fields: [doctorId], references: [id])
  guestDoctor        GuestDoctorProfile?       @relation(fields: [guestDoctorId], references: [id])
  guestAssignment    GuestDoctorAssignment?    @relation(fields: [guestAssignmentId], references: [id])
  patient            Patient                   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  registration       Registration?             @relation(fields: [registrationId], references: [id])
  prescriptions      Prescription[]
  radiologyOrders    RadiologyOrder[]
  referrals          Referral[]
  vitals             VitalSign[]

  @@index([patientId])
  @@index([doctorId])
  @@index([guestDoctorId])
  @@map("medical_records")
}

model VitalSign {
  id              String        @id @default(uuid())
  medicalRecordId String
  temperature     Float?
  bloodPressure   String?
  heartRate       Int?
  respiratoryRate Int?
  weight          Float?
  height          Float?
  bloodOxygen     Float?
  notes           String?
  recordedAt      DateTime      @default(now())
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@index([medicalRecordId])
  @@map("vital_signs")
}

model Referral {
  id              String        @id @default(uuid())
  medicalRecordId String
  type            String
  toClinicId      String?
  toDepartmentId  String?
  toHospitalName  String?
  referralDate    DateTime      @default(now())
  notes           String?
  status          String        @default("pending")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  toClinic        Clinic?       @relation(fields: [toClinicId], references: [id])
  toDepartment    Department?   @relation(fields: [toDepartmentId], references: [id])

  @@index([medicalRecordId])
  @@map("referrals")
}

model MedicalRecordAttachment {
  id              String        @id @default(uuid())
  medicalRecordId String
  fileUrl         String
  fileName        String
  fileType        String
  fileSize        Int?
  uploadedAt      DateTime      @default(now())
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@index([medicalRecordId])
  @@map("medical_record_attachments")
}

model ClinicalTemplate {
  id        String   @id @default(uuid())
  name      String
  type      String
  content   Json
  doctorId  String?
  clinicId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clinical_templates")
}

model MedicalRecordService {
  id              String        @id @default(uuid())
  medicalRecordId String
  serviceId       String
  quantity        Int           @default(1)
  price           Float
  notes           String?
  createdAt       DateTime      @default(now())
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  service         Service       @relation(fields: [serviceId], references: [id])

  @@index([medicalRecordId])
  @@map("medical_record_services")
}

model Prescription {
  id               String             @id @default(uuid())
  prescriptionNo   String             @unique
  medicalRecordId  String
  patientId        String
  doctorId         String
  prescriptionDate DateTime
  notes            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  counselingGiven  Boolean            @default(false)
  dispenseDate     DateTime?
  dispenseStatus   String             @default("pending")
  pharmacistId     String?
  items            PrescriptionItem[]
  doctor           Doctor             @relation(fields: [doctorId], references: [id])
  medicalRecord    MedicalRecord      @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  patient          Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([doctorId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String                      @id @default(uuid())
  prescriptionId String
  medicineId     String?
  quantity       Int
  dosage         String
  frequency      String
  duration       String
  instructions   String?
  isRacikan      Boolean                     @default(false)
  racikanName    String?
  formulaId      String?
  tuslahPrice    Float                       @default(0)
  components     PrescriptionItemComponent[]
  formula        CompoundFormula?            @relation(fields: [formulaId], references: [id])
  medicine       Medicine?                   @relation(fields: [medicineId], references: [id])
  prescription   Prescription                @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
  @@map("prescription_items")
}

model PrescriptionItemComponent {
  id                 String           @id @default(uuid())
  prescriptionItemId String
  medicineId         String
  quantity           Float
  unit               String?
  medicine           Medicine         @relation(fields: [medicineId], references: [id])
  prescriptionItem   PrescriptionItem @relation(fields: [prescriptionItemId], references: [id], onDelete: Cascade)

  @@index([prescriptionItemId])
  @@map("prescription_item_components")
}

/// Template formula standar untuk obat racikan.
/// Dokter/Apoteker cukup memilih formula, komponen terisi otomatis.
model CompoundFormula {
  id                  String                @id @default(uuid())
  formulaCode         String                @unique
  formulaName         String
  description         String?
  category            String?
  dosageForm          String?
  defaultQty          Int                   @default(10)
  defaultDosage       String?
  defaultFrequency    String?
  defaultDuration     String?
  defaultInstructions String?
  tuslahPrice         Float                 @default(0)
  isActive            Boolean               @default(true)
  clinicId            String?
  createdBy           String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  deletedAt           DateTime?
  items               CompoundFormulaItem[]
  clinic              Clinic?               @relation(fields: [clinicId], references: [id])
  prescriptionItems   PrescriptionItem[]
  productMaster       ProductMaster?

  @@index([clinicId])
  @@index([category])
  @@index([isActive])
  @@map("compound_formulas")
}

/// Komponen bahan baku dari sebuah formula racikan.
model CompoundFormulaItem {
  id         String          @id @default(uuid())
  formulaId  String
  medicineId String
  quantity   Float
  unit       String?
  notes      String?
  sortOrder  Int             @default(0)
  formula    CompoundFormula @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  medicine   Medicine        @relation(fields: [medicineId], references: [id])

  @@index([formulaId])
  @@index([medicineId])
  @@map("compound_formula_items")
}

model Medicine {
  id                         String                      @id @default(uuid())
  medicineName               String
  genericName                String?
  description                String?
  dosageForm                 String?
  strength                   String?
  manufacturer               String?
  batchNumber                String?
  expiryDate                 DateTime?
  isActive                   Boolean                     @default(true)
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  clinicId                   String?
  image                      String?
  medicineCode               String?
  compoundFormulaItems       CompoundFormulaItem[]
  clinic                     Clinic?                     @relation(fields: [clinicId], references: [id])
  prescriptionItemComponents PrescriptionItemComponent[]
  prescriptionItems          PrescriptionItem[]
  productMaster              ProductMaster?

  @@index([medicineName])
  @@index([clinicId])
  @@map("medicines")
}

model Service {
  id                    String                 @id @default(uuid())
  serviceCode           String                 @unique
  serviceName           String
  description           String?
  category              String?
  unit                  String?
  price                 Float
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  clinicId              String?
  categoryId            String?
  coaId                 String?
  doctorFee             Float                  @default(0)
  departmentId          String?
  appointmentServices   AppointmentService[]
  invoiceItems          InvoiceItem[]
  medicalRecordServices MedicalRecordService[]
  serviceCategory       ServiceCategory?       @relation(fields: [categoryId], references: [id])
  clinic                Clinic?                @relation(fields: [clinicId], references: [id])
  coa                   ChartOfAccount?        @relation(fields: [coaId], references: [id])
  department            Department?            @relation(fields: [departmentId], references: [id])

  @@index([serviceCode])
  @@index([categoryId])
  @@index([coaId])
  @@index([departmentId])
  @@map("services")
}

model ServiceCategory {
  id           String    @id @default(uuid())
  categoryName String    @unique
  description  String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  services     Service[]

  @@map("service_categories")
}

model AppointmentService {
  id            String      @id @default(uuid())
  appointmentId String
  serviceId     String
  quantity      Int         @default(1)
  price         Float
  discount      Float       @default(0)
  subtotal      Float
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id])

  @@index([appointmentId])
  @@map("appointment_services")
}

model ProductMaster {
  id                 String           @id @default(uuid())
  masterCode         String           @unique
  masterName         String
  description        String?
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  medicineId         String?          @unique
  categoryId         String?
  image              String?
  brand              String?
  productType        String?
  defaultUnit        String?          @default("pcs")
  manufacturer       String?
  minStock           Int?             @default(0)
  purchasePrice      Float?           @default(0)
  reorderPoint       Int?             @default(0)
  sellingPrice       Float?           @default(0)
  purchaseUnit       String?          @default("box")
  sku                String?          @unique
  storageUnit        String?          @default("pcs")
  supplier           String?
  usedUnit           String?          @default("pcs")
  qtyPerPurchaseUnit Float?           @default(1)
  qtyPerStorageUnit  Float?           @default(1)
  compoundFormulaId  String?          @unique
  assets             Asset[]
  productCategory    ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  compoundFormula    CompoundFormula? @relation(fields: [compoundFormulaId], references: [id])
  medicine           Medicine?        @relation(fields: [medicineId], references: [id])
  products           Product[]

  @@index([masterCode])
  @@index([categoryId])
  @@map("product_masters")
}

model ProductCategory {
  id             String          @id @default(uuid())
  categoryName   String          @unique
  description    String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  productMasters ProductMaster[]

  @@map("product_categories")
}

model Product {
  id                          String                       @id @default(uuid())
  masterProductId             String
  productCode                 String
  sku                         String
  productName                 String
  productType                 String?
  description                 String?
  unit                        String
  purchaseUnit                String
  storageUnit                 String
  usedUnit                    String
  qtyPerPurchaseUnit          Float?                       @default(1)
  qtyPerStorageUnit           Float?                       @default(1)
  quantity                    Float                        @default(0)
  minimumStock                Int
  reorderQuantity             Int
  purchasePrice               Float
  sellingPrice                Float
  supplier                    String?
  lastPurchaseDate            DateTime?
  expiryDate                  DateTime?
  isActive                    Boolean                      @default(true)
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  clinicId                    String?
  deletedAt                   DateTime?
  branchPrices                BranchProductPrice[]
  transferItems               InterBranchTransfer[]
  inventoryBatches            InventoryBatch[]
  inventoryMutations          InventoryMutation[]
  returnItems                 InventoryReturn[]
  inventoryStocks             InventoryStock[]
  procurementItems            ProcurementItem[]
  conversionRules             ProductUnitConversion[]
  clinic                      Clinic?                      @relation(fields: [clinicId], references: [id])
  masterProduct               ProductMaster                @relation(fields: [masterProductId], references: [id], onDelete: Cascade)
  stockOpnameItems            StockOpnameItem[]
  directMedicinePurchaseItems DirectMedicinePurchaseItem[]

  @@unique([productCode, clinicId])
  @@unique([sku, clinicId])
  @@index([productCode])
  @@index([sku])
  @@index([masterProductId])
  @@map("products")
}

model Asset {
  id                  String             @id @default(uuid())
  assetCode           String             @unique
  assetName           String
  assetType           String
  category            String
  description         String?
  serialNumber        String?
  manufacturer        String?
  model               String?
  purchaseDate        DateTime
  purchasePrice       Float
  currentValue        Float?
