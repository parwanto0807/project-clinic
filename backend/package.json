{
  "name": "clinic-backend",
  "version": "1.0.0",
  "description": "Backend API for Clinic WebApp",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS='--max-old-space-size=4096' tsx watch --ignore './public/uploads/**/*' --ignore './backups/**/*' --ignore './scratch/**/*' src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "seed:coa": "tsx scripts/seed-coa-pro.ts",
    "seed:system-accounts": "tsx scripts/seed-inventory-system-accounts.ts",
    "inventory:sync": "tsx scripts/retroactive-inventory-sync.ts",
    "inventory:sync:dry": "tsx scripts/retroactive-inventory-sync.ts --dry-run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "cross-env": "^10.1.0",
    "prisma": "^6.19.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
